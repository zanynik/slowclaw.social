{
  "name": "slowclaw-social-web",
  "private": true,
  "version": "0.1.0",
  "license": "(MIT OR Apache-2.0)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:tauri": "tsc && SLOWCLAW_WEB_BASE=./ vite build",
    "prepare:desktop-sidecar": "node ./scripts/prepare-desktop-sidecar.mjs",
    "build:tauri:desktop": "npm run prepare:desktop-sidecar && npm run build:tauri",
    "preview": "vite preview",
    "package:macos": "npm run tauri build -- --bundles app,dmg",
    "tauri": "tauri",
    "tauri:ios:init": "tauri ios init",
    "tauri:ios:dev": "tauri ios dev --open --host",
    "tauri:android:init": "tauri android init",
    "tauri:android:dev": "tauri android dev --open --host"
  },
  "dependencies": {
    "@atproto/api": "^0.13.24",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
